{
  "name": "harness-backend",
  "version": "0.0.0",
  "description": "mediness backend role plugin (API 설계, DB 마이그레이션, Python/PG)",
  "autoUpdate": true,
  "mcpServers": {
    "harness-github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${HARNESS_GITHUB_TOKEN}"
      },
      "condition": "${HARNESS_MCP_GITHUB_ENABLED:-true}"
    }
  }
}
