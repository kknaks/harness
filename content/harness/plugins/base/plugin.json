{
  "name": "harness",
  "version": "0.1.0",
  "description": "mediness 단일 plugin — /harness init 으로 role-templates 를 프로젝트 .claude/ 로 scaffold",
  "autoUpdate": true,
  "mcpServers": {
    "harness-github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${HARNESS_GITHUB_TOKEN}"
      },
      "condition": "${HARNESS_MCP_GITHUB_ENABLED:-true}"
    }
  }
}
